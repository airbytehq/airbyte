{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "folder": {
      "type": "string",
      "description": "Model folder/category (e.g. checkpoints, loras, vae)"
    },
    "name": {
      "type": "string",
      "description": "Model filename"
    },
    "path": {
      "type": ["string", "null"],
      "description": "Full model path within the folder"
    },
    "pathIndex": {
      "type": ["integer", "null"],
      "description": "Index of the path in the folder's path list"
    }
  }
}
