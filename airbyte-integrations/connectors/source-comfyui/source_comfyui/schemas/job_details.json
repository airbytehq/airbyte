{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Job UUID"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "completed", "failed", "cancelled"],
      "description": "Current job status"
    },
    "create_time": {
      "type": "integer",
      "description": "Unix timestamp in seconds"
    },
    "update_time": {
      "type": ["integer", "null"],
      "description": "Last update Unix timestamp in seconds"
    },
    "workflow_id": {
      "type": ["string", "null"],
      "description": "Workflow graph UUID"
    },
    "workflow": {
      "type": ["object", "null"],
      "description": "Full ComfyUI workflow graph (JSON DAG)"
    },
    "outputs": {
      "type": ["object", "null"],
      "description": "Full outputs from ComfyUI, keyed by node ID"
    },
    "preview_output": {
      "type": ["object", "null"],
      "description": "Primary preview output"
    },
    "outputs_count": {
      "type": ["integer", "null"],
      "description": "Total output files"
    },
    "execution_error": {
      "type": ["object", "null"],
      "description": "Structured error for failed jobs",
      "properties": {
        "node_id": {
          "type": "string",
          "description": "ID of the node that errored"
        },
        "node_type": {
          "type": "string",
          "description": "Type of the node that errored"
        },
        "exception_message": {
          "type": "string",
          "description": "Error message"
        },
        "exception_type": {
          "type": "string",
          "description": "Error class name"
        }
      }
    },
    "execution_status": {
      "type": ["object", "null"],
      "description": "ComfyUI execution status and timeline"
    },
    "execution_meta": {
      "type": ["object", "null"],
      "description": "Node-level execution metadata"
    },
    "execution_start_time": {
      "type": ["integer", "null"],
      "description": "Execution start time as Unix timestamp in milliseconds"
    },
    "execution_end_time": {
      "type": ["integer", "null"],
      "description": "Execution end time as Unix timestamp in milliseconds"
    }
  }
}
