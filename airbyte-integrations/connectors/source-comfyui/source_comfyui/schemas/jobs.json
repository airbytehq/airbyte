{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Job UUID"
    },
    "status": {
      "type": "string",
      "enum": [
        "waiting_to_dispatch",
        "pending",
        "in_progress",
        "completed",
        "failed",
        "cancelled",
        "error"
      ],
      "description": "Current job status"
    },
    "create_time": {
      "type": "integer",
      "description": "Unix timestamp in seconds"
    },
    "workflow_id": {
      "type": ["string", "null"],
      "description": "Workflow graph UUID"
    },
    "execution_error": {
      "type": ["object", "null"],
      "description": "Structured error for failed jobs",
      "properties": {
        "node_id": {
          "type": "string",
          "description": "ID of the node that errored"
        },
        "node_type": {
          "type": "string",
          "description": "Type of the node that errored"
        },
        "exception_message": {
          "type": "string",
          "description": "Error message"
        },
        "exception_type": {
          "type": "string",
          "description": "Error class name"
        }
      }
    },
    "preview_output": {
      "type": ["object", "null"],
      "description": "Primary preview output"
    },
    "outputs_count": {
      "type": ["integer", "null"],
      "description": "Total output files"
    },
    "execution_start_time": {
      "type": ["integer", "null"],
      "description": "Execution start time as Unix timestamp in milliseconds"
    },
    "execution_end_time": {
      "type": ["integer", "null"],
      "description": "Execution end time as Unix timestamp in milliseconds"
    }
  }
}
