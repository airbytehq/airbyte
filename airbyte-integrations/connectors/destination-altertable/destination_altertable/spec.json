{
  "documentationUrl": "https://docs.airbyte.com/integrations/destinations/altertable",
  "supported_destination_sync_modes": ["overwrite", "append", "append_dedup"],
  "supportsIncremental": true,
  "supportsNormalization": false,
  "supportsDBT": false,
  "connectionSpecification": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Destination Altertable",
    "type": "object",
    "required": ["username", "password", "catalog", "schema"],
    "additionalProperties": true,
    "properties": {
      "username": {
        "title": "Username",
        "type": "string",
        "description": "Your Altertable lakehouse username.",
        "order": 0
      },
      "password": {
        "title": "Password",
        "type": "string",
        "description": "Your Altertable lakehouse password.",
        "airbyte_secret": true,
        "order": 1
      },
      "catalog": {
        "title": "Catalog",
        "type": "string",
        "description": "The target catalog where data will be written.",
        "examples": ["my_catalog"],
        "order": 2
      },
      "schema": {
        "title": "Schema",
        "type": "string",
        "description": "The schema within the catalog to write data to.",
        "examples": ["main", "public"],
        "order": 3
      },
      "host": {
        "title": "Host",
        "type": "string",
        "description": "Hostname of the Altertable Flight SQL server.",
        "examples": ["flight.altertable.ai"],
        "default": "flight.altertable.ai",
        "order": 4
      },
      "port": {
        "title": "Port",
        "type": "integer",
        "description": "Port of the Altertable Flight SQL server.",
        "examples": [443],
        "default": 443,
        "order": 5
      },
      "tls": {
        "title": "Use TLS",
        "type": "boolean",
        "description": "Whether to use TLS for the connection to Altertable. Recommended for production.",
        "default": true,
        "order": 6
      }
    }
  }
}
