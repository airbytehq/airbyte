{
  "documentationUrl": "https://docs.airbyte.com/integrations/sources/tiktok-organic",
  "connectionSpecification": {
    "type": "object",
    "required": ["client_key", "client_secret", "refresh_token", "open_id"],
    "properties": {
      "client_key": {
        "title": "Client Key",
        "type": "string",
        "description": "Your TikTok App Client Key.",
        "airbyte_secret": true
      },
      "client_secret": {
        "title": "Client Secret",
        "type": "string",
        "description": "Your TikTok App Client Secret.",
        "airbyte_secret": true
      },
      "refresh_token": {
        "title": "Refresh Token",
        "type": "string",
        "description": "The long-lived refresh token obtained after user authorization.",
        "airbyte_secret": true
      },
      "open_id": {
        "title": "Open ID / Business ID",
        "type": "string",
        "description": "The TikTok Business Account ID (Open ID)."
      },
      "start_date": {
        "title": "Start Date",
        "type": "string",
        "description": "The date from which you'd like to start syncing data (YYYY-MM-DD). Defaults to 30 days ago if not set.",
        "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
        "examples": [
          "2024-01-01"
        ]
      }
    }
  }
}
